<view class="page">
  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <block wx:else>
    <view class="card detail-card">
      <view class="row">
        <view class="card-title detail-title">{{service.name}}</view>
        <view class="status">{{order.statusText}}</view>
      </view>
      <view class="card-subtitle">{{order.timeText}}</view>
      <view class="price">{{order.priceText}}</view>
    </view>

    <view class="section">
      <view class="section-title">服务进度</view>
      <view class="card content-card progress-card">
        <view wx:for="{{steps}}" wx:key="label" class="progress-step {{item.active ? 'progress-step-active' : ''}}">
          <view class="progress-dot"></view>
          <view class="progress-label">{{item.label}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">服务信息</view>
      <view class="card content-card">
        <view class="info-row">
          <view class="muted">项目</view>
          <view>{{service.name}}</view>
        </view>
        <view class="info-row">
          <view class="muted">技师</view>
          <view>{{therapist.name}}</view>
        </view>
        <view class="info-row">
          <view class="muted">日期</view>
          <view>{{order.appointmentDate}}</view>
        </view>
        <view class="info-row">
          <view class="muted">时间</view>
          <view>{{order.timeRangeText}}</view>
        </view>
        <view class="info-row">
          <view class="muted">门店电话</view>
          <view class="link-text" bindtap="callStore">{{store.phone}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">联系人</view>
      <view class="card content-card">
        <view class="info-row">
          <view class="muted">姓名</view>
          <view>{{order.contactName}}</view>
        </view>
        <view class="info-row">
          <view class="muted">手机号</view>
          <view>{{order.contactPhone}}</view>
        </view>
        <view class="info-row">
          <view class="muted">备注</view>
          <view>{{order.userNoteText}}</view>
        </view>
      </view>
    </view>

    <view class="footer-action" wx:if="{{canCancel || canBookAgain}}">
      <view wx:if="{{canCancel}}" class="btn btn-secondary footer-btn" bindtap="cancelOrder">取消预约</view>
      <view wx:if="{{canBookAgain}}" class="btn footer-btn" bindtap="bookAgain">再次预约</view>
    </view>
  </block>
</view>
