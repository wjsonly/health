.category-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 22rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.service-image {
  border-radius: 16rpx;
  height: 260rpx;
  margin-bottom: 22rpx;
  width: 100%;
}

.category-tab {
  background: #ffffff;
  border: 1rpx solid #dbe5dd;
  border-radius: 999rpx;
  color: #526057;
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
  padding: 12rpx 24rpx;
}

.category-tab-active {
  background: #2f6b4f;
  border-color: #2f6b4f;
  color: #ffffff;
}

.card-main {
  flex: 1;
  padding-right: 18rpx;
}

.card-kicker {
  color: #b15d36;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 30rpx;
  margin-bottom: 6rpx;
}

.tag-row {
  margin-top: 16rpx;
}

.card-actions {
  align-items: center;
  display: flex;
  gap: 14rpx;
  justify-content: space-between;
  margin-top: 18rpx;
}

.mini-link {
  color: #66706a;
  font-size: 24rpx;
  font-weight: 700;
}

.btn-small {
  font-size: 24rpx;
  height: 64rpx;
  line-height: 64rpx;
  min-width: 148rpx;
  padding: 0 20rpx;
}
