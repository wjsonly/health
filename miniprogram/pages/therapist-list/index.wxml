<view class="page">
  <view class="section-title">选择技师</view>
  <block wx:if="{{loading}}">
    <view class="loading">加载中...</view>
  </block>
  <block wx:elif="{{!therapists.length}}">
    <view class="empty">暂无可预约技师</view>
  </block>
  <block wx:else>
    <view
      wx:for="{{therapists}}"
      wx:key="id"
      class="card list-card therapist-card"
      data-id="{{item.id}}"
      bindtap="goDetail"
    >
      <view class="avatar">{{item.initial}}</view>
      <view class="therapist-info">
        <view class="row">
          <view class="card-title">{{item.name}}</view>
          <view class="status">{{item.availableText}}</view>
        </view>
        <view class="card-subtitle">{{item.level}} · {{item.yearsText}}</view>
        <view class="tag-row">
          <view class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</view>
        </view>
        <view class="card-subtitle">{{item.introText}}</view>
        <view class="card-actions">
          <view class="mini-link">查看资料</view>
          <view class="btn btn-small" data-id="{{item.id}}" catchtap="bookTherapist">预约TA</view>
        </view>
      </view>
    </view>
  </block>
</view>
