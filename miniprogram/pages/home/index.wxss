.button-row .btn {
  flex: 1;
}

.hero-badge {
  background: rgba(255, 255, 255, 0.14);
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.9);
  display: inline-flex;
  font-size: 22rpx;
  line-height: 30rpx;
  margin-bottom: 16rpx;
  padding: 8rpx 14rpx;
}

.trust-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.trust-pill {
  background: rgba(255, 255, 255, 0.14);
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 22rpx;
  line-height: 30rpx;
  padding: 8rpx 14rpx;
}

.hero-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.hero-actions .btn {
  flex: 1;
}

.hero-primary {
  background: #ffffff;
  color: #2f6b4f;
}

.hero-secondary {
  background: rgba(255, 255, 255, 0.14);
  color: #ffffff;
}

.quick-grid {
  display: grid;
  gap: 14rpx;
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.quick-item {
  background: #ffffff;
  border: 1rpx solid #e1e7df;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 22rpx rgba(31, 47, 39, 0.04);
  color: #244333;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 32rpx;
  padding: 22rpx 8rpx;
  text-align: center;
}

.section-heading {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-heading .section-title {
  margin-bottom: 0;
}

.section-link {
  color: #2f6b4f;
  font-size: 24rpx;
  font-weight: 700;
}

.card-main {
  flex: 1;
  padding-right: 18rpx;
}

.card-kicker {
  color: #b15d36;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 30rpx;
  margin-bottom: 6rpx;
}

.tag-row {
  margin-top: 16rpx;
}

.card-actions {
  align-items: center;
  display: flex;
  gap: 14rpx;
  justify-content: space-between;
  margin-top: 18rpx;
}

.mini-link {
  color: #66706a;
  font-size: 24rpx;
  font-weight: 700;
}

.btn-small {
  font-size: 24rpx;
  height: 64rpx;
  line-height: 64rpx;
  min-width: 148rpx;
  padding: 0 20rpx;
}

.therapist-card {
  align-items: center;
  display: flex;
}

.therapist-info {
  flex: 1;
}
