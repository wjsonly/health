<view class="page">
  <view class="section-title">我的订单</view>
  <block wx:if="{{loading}}">
    <view class="loading">加载中...</view>
  </block>
  <block wx:elif="{{!orders.length}}">
    <view class="empty-card">
      <view class="empty">暂无预约订单</view>
      <view class="btn" bindtap="goBooking">去预约</view>
    </view>
  </block>
  <block wx:else>
    <view
      wx:for="{{orders}}"
      wx:key="id"
      class="card list-card"
      data-id="{{item.id}}"
      bindtap="goDetail"
    >
      <view class="row">
        <view class="card-title">{{item.serviceName}}</view>
        <view class="status">{{item.statusText}}</view>
      </view>
      <view class="card-subtitle">{{item.therapistName}}</view>
      <view class="card-subtitle">{{item.timeText}}</view>
      <view class="row order-footer">
        <view class="price">{{item.priceText}}</view>
        <view class="order-actions">
          <view class="mini-link">查看详情</view>
          <view
            wx:if="{{item.canBookAgain}}"
            class="btn btn-small"
            data-service-id="{{item.serviceItemId}}"
            data-therapist-id="{{item.therapistId}}"
            catchtap="bookAgain"
          >
            再次预约
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
