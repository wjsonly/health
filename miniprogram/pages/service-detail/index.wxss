.detail-hero,
.content-card {
  padding: 28rpx;
}

.detail-image {
  border-radius: 16rpx;
  height: 340rpx;
  margin-bottom: 24rpx;
  width: 100%;
}

.detail-title {
  color: #1f2f27;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 52rpx;
}

.detail-price {
  margin-top: 24rpx;
}

.card-kicker {
  color: #b15d36;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 30rpx;
  margin-bottom: 8rpx;
}

.tag-row {
  margin-top: 18rpx;
}

.original-price {
  text-decoration: line-through;
}

.bullet-row {
  align-items: flex-start;
  display: flex;
  margin-bottom: 18rpx;
}

.bullet-row:last-child {
  margin-bottom: 0;
}

.bullet-dot {
  background: #2f6b4f;
  border-radius: 50%;
  flex-shrink: 0;
  height: 12rpx;
  margin: 12rpx 16rpx 0 0;
  width: 12rpx;
}

.bullet-text {
  color: #405047;
  font-size: 26rpx;
  line-height: 38rpx;
}

.guarantee-grid {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.guarantee-item {
  background: #f5f8f4;
  border-radius: 8rpx;
  color: #2f6b4f;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
  padding: 16rpx;
  text-align: center;
}

.footer-action {
  align-items: center;
  background: #ffffff;
  border-top: 1rpx solid #e1e7df;
  bottom: 0;
  box-sizing: border-box;
  display: flex;
  gap: 18rpx;
  left: 0;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  position: sticky;
  right: 0;
}

.footer-price {
  color: #b15d36;
  flex: 1;
  font-size: 34rpx;
  font-weight: 800;
}

.footer-btn {
  min-width: 260rpx;
}
